{
  "name": "brief-mcp",
  "version": "0.1.0",
  "description": "MCP server for BRIEF.md project context management",
  "license": "MIT",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "brief-mcp": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "assets/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build:ts": "tsup",
    "build:assets": "copyfiles \"assets/**/*\" dist/",
    "build": "npm run build:ts && npm run build:assets",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/",
    "typecheck": "tsc --noEmit",
    "check:size": "npm pack --dry-run 2>&1 | tail -1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "stream-json": "^1.9.1"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@types/node": "^25.3.3",
    "@types/stream-json": "^1.7.8",
    "@vitest/coverage-v8": "latest",
    "copyfiles": "latest",
    "fast-check": "latest",
    "husky": "latest",
    "tsup": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/brief-mcp/brief-mcp.git"
  },
  "keywords": [
    "mcp",
    "brief",
    "context",
    "ai",
    "model-context-protocol"
  ]
}
